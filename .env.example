# KoboToolbox credentials. All three are optional: if any are missing,
# `app/api/feedback` falls back to the bundled `data/feedback.json` so
# local development still works without secrets.

# Personal API token from Kobo Account Settings → Security.
#   1. Log in to https://kf.kobotoolbox.org (or your regional server)
#   2. Profile icon → Account Settings → Security
#   3. Click "Display" to view your existing token, or "Regenerate" to
#      rotate. NEVER commit this value to git.
KOBO_API_TOKEN=

# Asset (form) UID. Visible in the Kobo form URL:
#   https://<server>/#/forms/<UID>/summary
KOBO_ASSET_UID=

# Server base URL. Defaults to https://kf.kobotoolbox.org (Global).
# Set to https://eu.kobotoolbox.org for the European Union / humanitarian
# server, or to a self-hosted instance.
KOBO_BASE_URL=
